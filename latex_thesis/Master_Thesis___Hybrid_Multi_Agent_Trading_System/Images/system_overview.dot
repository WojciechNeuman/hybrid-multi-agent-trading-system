// Hybrid Multi-Agent Trading System — high-level architecture
// Rendered with: dot -Tpng -Gdpi=200 system_overview.dot -o system_overview.png
digraph SystemOverview {
    rankdir=TB;
    bgcolor="white";
    splines=true;
    nodesep=0.40;
    ranksep=0.55;
    node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=11,
          color="#33485f", penwidth=1.4, margin="0.16,0.09"];
    edge [color="#5b6b7a", arrowsize=0.8, penwidth=1.2];

    // ---- Data ingestion ----
    DATA [label="Data Ingestion\nBTC/USDT OHLCV + taker flow,\nCoinGecko, Fear & Greed\n2017–2026, 1h candles",
          fillcolor="#d7e3ef"];

    // ---- Unified feature library ----
    FEAT [label="Unified Feature Library\n~285 leakage-audited candidate features\n(technical / external / microstructure / structural)",
          fillcolor="#cfe0ec"];

    // ---- Learned agents ----
    subgraph cluster_learned {
        label="Learned Agents — walk-forward out-of-sample signals";
        labelloc="t";
        fontname="Helvetica-Bold";
        fontsize=12;
        style="dashed,rounded";
        color="#8a99a8";
        margin=12;

        LGBM   [label="LightGBM (gradient boosting)\nsliding 2-year WFO, monthly step\n50-feature relevance–redundancy selection\n+9.6% · Sharpe 0.14",
                fillcolor="#cdeccd"];
        PATCH  [label="PatchTST (patch transformer)\nchronological split, temp-scaled\nshort-side Triple-Barrier specialist\n+77.8% · Sharpe 1.64",
                fillcolor="#f6cccc"];
        MAMBA  [label="Mamba (state-space model)\nexpanding WFO from 2019\nfold-percentile long specialist\n+67.4% · Sharpe 0.99",
                fillcolor="#d7d0ec"];
        TCN    [label="TCN (dilated causal conv.)\nexpanding WFO, 3-class TBM\nboth-side skill-selected grid\n+36.4% · Sharpe 0.58",
                fillcolor="#bfe6e6"];
    }

    // ---- Rule-based agents ----
    subgraph cluster_rules {
        label="Rule-Based Agents — fixed economic logic";
        labelloc="t";
        fontname="Helvetica-Bold";
        fontsize=12;
        style="dashed,rounded";
        color="#8a99a8";
        margin=12;

        TREND  [label="Trend following\nMA / SuperTrend / MACD\n+62.5% · Sharpe 0.58",
                fillcolor="#e9e2c8"];
        VOLB   [label="Volatility breakout\nrange break + squeeze\n+34.7% · Sharpe 0.44",
                fillcolor="#e9e2c8"];
        DOM    [label="Dominance rotation\ncross-asset capital flow\n+155.1% (diversifier, not alpha)",
                fillcolor="#e9e2c8"];
    }

    // ---- Allocation layer ----
    ALLOC  [label="Capped Inverse-Volatility Allocator (final)\nleak-free risk parity, cap 2/N\n+56.8% · Sharpe 2.02 · MaxDD -5.9%",
            fillcolor="#cdeccd"];
    COORD  [label="Regime-gated Coordinator (ablation)\nsoftmax(trailing Sharpe) × competence\n+14.0% · Sharpe 0.33",
            fillcolor="#ead9d9"];

    // ---- Execution ----
    EXEC   [label="Execution & Evaluation\nshared ATR-bracket backtest (fees)\nOOS 2024-06-01 → 2026-05-31\nthree regimes: Chop / Bull / Bear",
            fillcolor="#f6cccc"];

    // ---- Edges ----
    DATA -> FEAT;
    FEAT -> LGBM;
    FEAT -> PATCH;
    FEAT -> MAMBA;
    FEAT -> TCN;
    FEAT -> TREND;
    FEAT -> VOLB;
    FEAT -> DOM;

    LGBM  -> ALLOC;  PATCH -> ALLOC;  MAMBA -> ALLOC;  TCN -> ALLOC;
    TREND -> ALLOC;  VOLB  -> ALLOC;  DOM   -> ALLOC;

    LGBM  -> COORD [style=dotted];  PATCH -> COORD [style=dotted];
    MAMBA -> COORD [style=dotted];  TCN   -> COORD [style=dotted];
    TREND -> COORD [style=dotted];  VOLB  -> COORD [style=dotted];
    DOM   -> COORD [style=dotted];

    ALLOC -> EXEC;
    COORD -> EXEC [style=dotted];

    { rank=same; ALLOC; COORD; }
}
